[submodule "vendor/sdl3"]
	path = vendor/sdl3
	url = https://github.com/libsdl-org/SDL.git
[submodule "vendor/json"]
	path = vendor/json
	url = https://github.com/nlohmann/json.git
[submodule "vendor/sdl3-image"]
	path = vendor/sdl3-image
	url = https://github.com/libsdl-org/SDL_image.git
[submodule "vendor/sdl3-mixer"]
	path = vendor/sdl3-mixer
	url = https://github.com/libsdl-org/SDL_mixer.git
[submodule "vendor/emsdk"]
	path = vendor/emsdk
	url = https://github.com/emscripten-core/emsdk.git
[submodule "vendor/rmlui"]
	path = vendor/rmlui
	url = https://github.com/mikke89/RmlUi.git
[submodule "vendor/freetype"]
	path = vendor/freetype
	url = https://gitlab.freedesktop.org/freetype/freetype.git
